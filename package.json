{
  "name": "entropi-backend",
  "version": "1.0.0",
  "description": "Financial event-sourcing backend with double-entry ledger",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:ci": "jest --ci --forceExit",
    "stress:orders": "tsx scripts/stress-orders.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "@fastify/swagger": "^9.6.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.9.0",
    "decimal.js": "^10.5.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "@types/jest": "^29.5.14",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4"
  }
}
